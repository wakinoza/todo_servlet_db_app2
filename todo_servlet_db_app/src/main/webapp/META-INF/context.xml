<?xml version="1.0" encoding="UTF-8"?>
<Context useHttpOnly="true">
  <Resource name="jdbc/test_db_read"
            auth="Container"
            type="javax.sql.DataSource"
            driverClassName="com.mysql.cj.jdbc.Driver"
            url="jdbc:mysql://${DB_HOST}:3306/${DB_NAME}?serverTimezone=Asia/Tokyo&amp;characterEncoding=UTF-8&amp;useServerPrepStmts=true"
            username="${DB_USERNAME_READ}"
            password="${DB_PASSWORD_READ}"
            maxTotal="20"
            maxIdle="10"
            maxWaitMillis="-1" />

  <Resource name="jdbc/test_db_write"
            auth="Container"
            type="javax.sql.DataSource"
            driverClassName="com.mysql.cj.jdbc.Driver"
            url="jdbc:mysql://${DB_HOST}:3306/${DB_NAME}?serverTimezone=Asia/Tokyo&amp;characterEncoding=UTF-8&amp;useServerPrepStmts=true"
            username="${DB_USERNAME_WRITE}"
            password="${DB_PASSWORD_WRITE}"
            maxTotal="20"
            maxIdle="10"
            maxWaitMillis="-1" />
</Context>